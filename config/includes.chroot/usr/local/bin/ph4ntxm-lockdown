#!/usr/bin/env python3
import os, subprocess, json, gi
gi.require_version('Gtk', '3.0')
from gi.repository import Gtk

STATUS_FILE = "/run/ph4ntxm-lockdown-status.json"
UFW_PATH = "/usr/sbin/ufw"

def check_root():
    if os.geteuid() != 0: exit(1)

def read_status():
    if os.path.exists(STATUS_FILE):
        try:
            with open(STATUS_FILE, "r") as f:
                return json.load(f).get("enabled", False)
        except: return False
    return False

def write_status(enabled):
    try:
        with open(STATUS_FILE, "w") as f:
            json.dump({"enabled": enabled}, f)
    except: pass

def enable_lockdown():
    try:
        subprocess.run([UFW_PATH, "default", "deny", "incoming"], check=True)
        subprocess.run([UFW_PATH, "default", "deny", "outgoing"], check=True)
        subprocess.run([UFW_PATH, "--force", "enable"], check=True)
        write_status(True)
        return True
    except: return False

def disable_lockdown():
    try:
        subprocess.run([UFW_PATH, "default", "allow", "incoming"], check=True)
        subprocess.run([UFW_PATH, "default", "allow", "outgoing"], check=True)
        subprocess.run([UFW_PATH, "--force", "enable"], check=True)
        write_status(False)
        return True
    except: return False

class LockdownDialog(Gtk.Window):
    def __init__(self):
        Gtk.Window.__init__(self, title="Lockdown")
        
        icon_path = "/usr/share/icons/Lyra-blue-dark/apps/scalable/ph4ntxm-lockdown.svg"
        if os.path.exists(icon_path):
            self.set_icon_from_file(icon_path)
            
        self.set_border_width(20)
        self.set_resizable(False)
        self.set_default_size(400, 150)
        self.set_position(Gtk.WindowPosition.CENTER)

        enabled = read_status()
        status_text = "Enabled" if enabled else "Disabled"
        prompt_text = (
            "<span size='small'>Lockdown all incoming and outgoing network traffic.</span>\n\n"
            f"Lockdown: <b>{status_text}</b>\n"
            f"Do you want to {'disable' if enabled else 'enable'} it?"
        )

        vbox = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=15)
        self.add(vbox)
        label = Gtk.Label()
        label.set_markup(prompt_text)
        label.set_justify(Gtk.Justification.CENTER)
        vbox.pack_start(label, True, True, 0)

        hbox = Gtk.Box(spacing=10)
        vbox.pack_start(hbox, True, True, 0)
        btn_yes = Gtk.Button(label="YES")
        btn_yes.connect("clicked", self.on_yes)
        hbox.pack_start(btn_yes, True, True, 0)
        btn_no = Gtk.Button(label="NO")
        btn_no.connect("clicked", self.on_no)
        hbox.pack_start(btn_no, True, True, 0)
        self.enabled = enabled

    def on_yes(self, widget):
        if self.enabled:
            if disable_lockdown(): self.close()
        else:
            if enable_lockdown(): self.close()

    def on_no(self, widget): self.close()

if __name__ == "__main__":
    check_root()
    win = LockdownDialog()
    win.connect("destroy", Gtk.main_quit)
    win.show_all()
    Gtk.main()